{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/__/auth/:path*",
      "destination": "/api/firebase-host?__fb_seg=auth&__fb_path=:path*"
    },
    {
      "source": "/__/firebase/:path*",
      "destination": "/api/firebase-host?__fb_seg=firebase&__fb_path=:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
