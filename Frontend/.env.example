# ─────────────────────────────────────────────
# Praecantator Frontend – Environment Variables
# ─────────────────────────────────────────────
# All variables MUST be prefixed with VITE_ to be
# exposed to the browser build.

# API — FastAPI backend
# VITE_API_URL  — HTTP fetch base for all API calls. Must include the /api suffix.
# VITE_API_BASE — Full backend URL used for WebSocket host derivation in use-websocket.ts.
#                 Keep in sync with VITE_API_URL.
#
# Local:       http://127.0.0.1:8000/api
# Production:  https://praecantator-api.onrender.com/api  (set in Vercel dashboard)
VITE_API_URL=http://127.0.0.1:8000/api
VITE_API_BASE=http://127.0.0.1:8000/api

# Firebase Web app (Firebase Console → Project settings → Your apps)
# For Google sign-in on Vercel: set AUTH_DOMAIN to the SPA hostname (e.g. your-app.vercel.app),
# NOT your-project.firebaseapp.com — after you add the /__/auth proxy or sync auth assets (see docs/DEPLOYMENT_FIREBASE.md).
# AUTH_DOMAIN is required for Google sign-in (legacy example: your-project-id.firebaseapp.com for default Firebase Hosting only)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional on Vercel: same value as VITE_FIREBASE_PROJECT_ID — lets /api/firebase-host read the id without a VITE_ prefix (server-only).
# FIREBASE_PROJECT_ID=

# MapLibre tile provider key (if required by your tile host)
# VITE_MAPTILER_KEY=your_maptiler_api_key_here

# Map style overrides (optional – leave blank to use defaults)
# VITE_MAP_STYLE_DARK=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json
# VITE_MAP_STYLE_LIGHT=https://basemaps.cartocdn.com/gl/positron-gl-style/style.json

# Feature flags
VITE_ENABLE_DEMO_MODE=false
