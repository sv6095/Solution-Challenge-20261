# Copy to .env.development (loaded automatically when ENVIRONMENT is not "production").
# See claude.md Section 2.

LLM_PROVIDER=groq
DB_PROVIDER=sqlite
CACHE_PROVIDER=memory
AUTH_PROVIDER=local

# CORS for local frontend(s). Comma-separated explicit origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Optional regex for additional domains (for example, Vercel previews).
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Optional signal sources
NEWSAPI_API_KEY=
GNEWS_API_KEY=

# Frankfurter / World Bank — no keys
# FRANKFURTER_API=
# WORLDBANK_API=

# Firestore off for pure local (DB_PROVIDER=sqlite forces SQLite even if below is true)
FIRESTORE_ENABLED=false

# Intelligence gap tracker controls
INTELLIGENCE_GAP_TRACKER_ENABLED=true
INTELLIGENCE_GAP_CONTEXT_QUALITY_MIN=75
INTELLIGENCE_GAP_SIGNAL_STALE_HOURS=24
INTELLIGENCE_GAP_SIGNAL_STALE_RATIO_THRESHOLD=0.4
INTELLIGENCE_GAP_SIGNAL_LOW_CORR_RATIO_THRESHOLD=0.5
INTELLIGENCE_GAP_MASTER_DATA_PENDING_THRESHOLD=20
INTELLIGENCE_GAP_REGISTRY_STALE_HOURS=720
