# Copy to .env.production and set ENVIRONMENT=production to load this file (see main.py).
# Secrets should prefer GCP Secret Manager in real deployments.

ENVIRONMENT=production

# Cloud Run / GCP: set GCP_PROJECT_ID so secret_manager.get_secret() can read Secret Manager.
GCP_PROJECT_ID=
LLM_PROVIDER=gemini
DB_PROVIDER=firestore
CACHE_PROVIDER=redis
AUTH_PROVIDER=firebase

# Disable dev auth bypass in production (see services/firebase_auth.py).
LOCAL_AUTH_BYPASS=false

GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
FIREBASE_PROJECT_ID=
FIRESTORE_ENABLED=true

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

FIREBASE_API_KEY=
GOOGLE_MAPS_API_KEY=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Emergency LLM fallback
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Intelligence gap tracker controls
INTELLIGENCE_GAP_TRACKER_ENABLED=true
INTELLIGENCE_GAP_CONTEXT_QUALITY_MIN=80
INTELLIGENCE_GAP_SIGNAL_STALE_HOURS=24
INTELLIGENCE_GAP_SIGNAL_STALE_RATIO_THRESHOLD=0.35
INTELLIGENCE_GAP_SIGNAL_LOW_CORR_RATIO_THRESHOLD=0.45
INTELLIGENCE_GAP_MASTER_DATA_PENDING_THRESHOLD=10
INTELLIGENCE_GAP_REGISTRY_STALE_HOURS=720
